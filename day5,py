  # Task 6: Logic Challenge

text = input("Enter a string: ")
nums = list(map(int, input("Enter numbers: ").split()))

# 1. Second highest number
unique = list(set(nums))
unique.sort()

if len(unique) >= 2:
    print("\nSecond highest:", unique[-2])
else:
    print("\nNot enough elements")

# 2. Frequency of characters
freq = {}

for ch in text:
    freq[ch] = freq.get(ch, 0) + 1

print("\nCharacter frequency:", freq)

# 3. Remove duplicates from list
no_dup = list(set(nums))
print("\nList without duplicates:", no_dup)
