  # Task 3: Nested Data Practice

students = []

# 1. Create list of 5 students
for i in range(5):
    name = input("Enter student name: ")
    marks = int(input("Enter marks: "))
    students.append({"name": name, "marks": marks})

# 2. Print all students
print("\nAll Students:")
for s in students:
    print(s)

# 3. Find average marks
total = sum(s["marks"] for s in students)
avg = total / len(students)
print("\nAverage Marks:", avg)

# 4. Find highest marks
top = max(students, key=lambda x: x["marks"])
print("\nTopper:", top)

# 5. Students with marks > 75
print("\nStudents with marks > 75:")
for s in students:
    if s["marks"] > 75:
        print(s)

